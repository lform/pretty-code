{
	"semi": true,
	"singleQuote": false,
	"tabWidth": 4,
	"printWidth": 120,
	"trailingComma": "es5",
	"arrowParens": "avoid",
	"htmlWhitespaceSensitivity": "css",
	"bracketSameLine": true,
	"proseWrap": "preserve",
	"jsxSingleQuote": false,
	"overrides": [
		{
			"files": ["*.blade.php"],
			"options": {
				"parser": "blade"
			}
		},
		{
			"files": ["*.antlers.html", "*.antlers.php"],
			"options": {
				"parser": "antlers"
			}
		},
		{
			"files": ["*.yaml", "*.yml"],
			"options": {
				"useTabs": false,
				"tabWidth": 2,
				"singleQuote": false
			}
		}
	],
	"plugins": [
		"prettier-plugin-antlers",
		"prettier-plugin-blade",
		"prettier-plugin-tailwindcss"
	]
}
