#!/bin/bash

# Current paths resolve from `vendor/.bin`
CURRENT_PATH=$(dirname $0)
PACKAGE_PATH=$(realpath "${CURRENT_PATH}/../lform/pretty-code")
ROOT_PATH=$(realpath "${CURRENT_PATH}/../../..")

copy_file() {
	local src="$1"
	local dest="$2"
	local suggestion="$3"

	if ! [ -f "${dest}" ]; then
		echo -e "Copying $(basename ${dest}) ..."
		cp "${src}" "${dest}"
		echo -e "... Done."
	else
		echo -e "$(basename ${dest}) already exists, copying suggestion to $(basename ${suggestion}) ..."
		cp "${src}" "${suggestion}"
		echo -e "... Done."
	fi
}

case "${1}" in
	init)
		copy_file \
			"${PACKAGE_PATH}/pint.json" \
			"${ROOT_PATH}/pint.json" \
			"${ROOT_PATH}/pint.suggestions.json"

		echo -e "Setting up Composer scripts..."
		composer config scripts."pretty:format:php" "vendor/bin/pint"
		echo -e "Added Composer script: pretty:format:php"
		echo -e "... Done."

		echo "Setup complete."
		;;
	*)
		echo -e "Usage: pretty-code init"
		;;
esac
